<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="Резюме-портфолио студента-программиста Никиты Брюханова. Python, Docker, SQL, Computer Vision, автоматизация">
    <meta name="author" content="Никита Брюханов">
    <title>Никита Брюханов | Программист · Портфолио</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            transition: background-color 0.3s ease, color 0.2s ease, border-color 0.2s;
        }

        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f8fafc;
            --text-primary: #0f172a;
            --text-secondary: #334155;
            --accent: #2563eb;
            --accent-hover: #1d4ed8;
            --border: #e2e8f0;
            --card-bg: #ffffff;
            --shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.02);
            --navbar-bg: rgba(255,255,255,0.9);
        }

        body.dark {
            --bg-primary: #0f172a;
            --bg-secondary: #1e293b;
            --text-primary: #f1f5f9;
            --text-secondary: #cbd5e1;
            --accent: #3b82f6;
            --accent-hover: #60a5fa;
            --border: #334155;
            --card-bg: #1e293b;
            --navbar-bg: rgba(15,23,42,0.95);
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            scroll-behavior: smooth;
            line-height: 1.5;
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* Navbar */
        .navbar {
            position: sticky;
            top: 0;
            backdrop-filter: blur(12px);
            background: var(--navbar-bg);
            border-bottom: 1px solid var(--border);
            z-index: 100;
            padding: 1rem 0;
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
            list-style: none;
        }

        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--accent);
        }

        .theme-toggle {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 2rem;
            padding: 0.5rem 1rem;
            cursor: pointer;
            font-weight: 500;
            color: var(--text-primary);
        }

        /* Header */
        .hero {
            padding: 3rem 0 2rem;
            text-align: center;
        }

        .avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            object-fit: cover;
            box-shadow: 0 20px 30px -12px rgba(0,0,0,0.2);
            margin-bottom: 1.5rem;
            border: 3px solid var(--accent);
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
        }

        .specialization {
            color: var(--accent);
            font-weight: 600;
            margin: 0.5rem 0;
        }

        .sell-pitch {
            max-width: 700px;
            margin: 1rem auto;
            color: var(--text-secondary);
        }

        .cta-button {
            background: var(--accent);
            color: white;
            border: none;
            padding: 0.75rem 1.8rem;
            border-radius: 2rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 1rem;
            display: inline-block;
            text-decoration: none;
        }

        .section-title {
            font-size: 1.8rem;
            margin: 2rem 0 1.5rem;
            border-left: 5px solid var(--accent);
            padding-left: 1rem;
        }

        /* cards grid */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.8rem;
            margin-bottom: 2rem;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 1.2rem;
            padding: 1.5rem;
            box-shadow: var(--shadow);
            transition: transform 0.2s ease, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1);
        }

        .card img, .cert-img {
            width: 100%;
            border-radius: 0.75rem;
            margin: 0.75rem 0;
            cursor: pointer;
        }

        .filter-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin-bottom: 1.8rem;
        }

        .filter-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            cursor: pointer;
        }

        .filter-btn.active {
            background: var(--accent);
            color: white;
            border-color: var(--accent);
        }

        /* SDLC interactive scheme */
        .sdlc-wrapper {
            background: var(--bg-secondary);
            border-radius: 2rem;
            padding: 2rem;
            margin: 2rem 0;
        }

        .sdlc-stages {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
        }

        .stage {
            background: var(--card-bg);
            border-radius: 1rem;
            padding: 1rem;
            text-align: center;
            flex: 1 1 120px;
            cursor: pointer;
            border: 1px solid var(--border);
            position: relative;
        }

        .stage:hover .tooltip {
            display: block;
        }

        .tooltip {
            display: none;
            position: absolute;
            bottom: 120%;
            left: 50%;
            transform: translateX(-50%);
            background: var(--text-primary);
            color: var(--bg-primary);
            padding: 0.75rem;
            border-radius: 0.8rem;
            width: 220px;
            font-size: 0.8rem;
            z-index: 10;
            white-space: normal;
            text-align: left;
        }

        .roadmap-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-top: 1rem;
        }

        .tag {
            background: var(--bg-secondary);
            border-radius: 2rem;
            padding: 0.3rem 1rem;
            font-size: 0.85rem;
        }

        footer {
            margin-top: 3rem;
            padding: 2rem 0;
            border-top: 1px solid var(--border);
            text-align: center;
            font-size: 0.85rem;
        }

        @media (max-width: 768px) {
            .nav-links {
                justify-content: center;
            }
            .section-title {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="container nav-container">
        <div style="font-weight: 700;">NB.dev</div>
        <ul class="nav-links">
            <li><a href="#home">Главная</a></li>
            <li><a href="#courses">Курсы</a></li>
            <li><a href="#projects">Проекты</a></li>
            <li><a href="#practice">Практика</a></li>
            <li><a href="#selfdev">Саморазвитие</a></li>
            <li><a href="#about">Обо мне</a></li>
        </ul>
        <button class="theme-toggle" id="themeToggle">🌙 Тёмная</button>
    </div>
</nav>

<main>
    <!-- Hero -->
    <section id="home" class="hero container">
        <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="Фотография" class="avatar" loading="lazy">
        <h1>Никита Анатольевич Брюханов</h1>
        <div class="specialization">Программист: Python • Docker • SQL • Computer Vision</div>
        <div class="sell-pitch">Разрабатываю настольные и мобильные приложения, автоматизирую ИТ-инфраструктуру и создаю надёжные системы на основе современных практик тестирования и контейнеризации.</div>
        <a href="#projects" class="cta-button">Смотреть проекты →</a>
    </section>

    <!-- Курсы с фильтрацией -->
    <section id="courses" class="container">
        <h2 class="section-title">📚 Пройденные курсы</h2>
        <div class="filter-buttons" id="courseFilters">
            <button class="filter-btn active" data-filter="all">Все</button>
            <button class="filter-btn" data-filter="python">Python</button>
            <button class="filter-btn" data-filter="ml">ML</button>
            <button class="filter-btn" data-filter="devops">DevOps</button>
        </div>
        <div id="coursesGrid" class="cards-grid"></div>
    </section>

    <!-- Проекты по МДК -->
    <section id="projects" class="container">
        <h2 class="section-title">💻 Проекты</h2>
        <div id="projectsGrid" class="cards-grid"></div>
    </section>

    <!-- Практика + Twine новелла -->
    <section id="practice" class="container">
        <h2 class="section-title">🏭 Практика & Коммерческие проекты</h2>
        <div id="practiceGrid" class="cards-grid"></div>
        <div class="card" style="margin-top: 1rem;">
            <h3>📖 Интерактивная новелла о практике</h3>
            <p>Ознакомьтесь с моим опытом в ГБПОУ МО «Люберецкий техникум им. Ю.А. Гагарина» через Twine-игру:</p>
            <a href="#" id="twineLink" target="_blank" class="cta-button" style="background: #2dd4bf; margin-top: 0.5rem;">Запустить новеллу (GitHub Pages)</a>
            <small style="display:block; margin-top:0.5rem;">*Новелла содержит фото с практики, задачи CI/CD, Docker, рефлексию.</small>
        </div>
    </section>

    <!-- Саморазвитие + SDLC -->
    <section id="selfdev" class="container">
        <h2 class="section-title">🧠 Саморазвитие & Roadmap</h2>
        <div class="roadmap-tags">
            <span class="tag">🐍 Python • FastAPI • PyQt</span>
            <span class="tag">🐳 Docker • Linux • Bash</span>
            <span class="tag">🗄️ SQLite/PostgreSQL</span>
            <span class="tag">📱 Kivy / Flutter</span>
            <span class="tag">🤖 Computer Vision / OpenCV</span>
            <span class="tag">🔐 ФСТЭК, РЕД ОС, Приказ №239</span>
        </div>
        <div class="sdlc-wrapper">
            <h3 style="margin-bottom: 1.5rem;">🔄 Жизненный цикл ПО (SDLC) — наведи на этап</h3>
            <div class="sdlc-stages" id="sdlcContainer"></div>
        </div>
    </section>

    <!-- Обо мне -->
    <section id="about" class="container">
        <h2 class="section-title">👤 Обо мне</h2>
        <div class="cards-grid">
            <div class="card">
                <h3>📖 Биография</h3>
                <p>Студент ГБПОУ МО «Люберецкий техникум имени Ю.А. Гагарина», специальность 09.02.07 «Информационные системы и программирование». Глубокий интерес к системному программированию, автоматизации, CV и защите данных. Работаю с РЕД ОС, Docker, OpenCV.</p>
                <p><strong>Год окончания:</strong> 2027</p>
            </div>
            <div class="card">
                <h3>⚙️ Навыки</h3>
                <p><strong>Языки:</strong> Python, SQL, Bash, JS (базовый), 1C</p>
                <p><strong>Инструменты:</strong> Docker, Git, Linux, OpenCV, PyTorch/TensorFlow (базово), Angular, PostgreSQL/MySQL/SQLite</p>
                <p><strong>Soft skills:</strong> аналитическое мышление, документирование, работа в команде, дисциплина</p>
            </div>
            <div class="card">
                <h3>🔗 Ссылки</h3>
                <p><i class="fab fa-github"></i> <a href="#">github.com/nikita-brukh</a><br>
                <i class="fab fa-telegram"></i> <a href="#">t.me/nikita_dev</a><br>
                <i class="fab fa-vk"></i> <a href="#">vk.com/nikita.coding</a><br>
                Yougile / Notion — по запросу</p>
            </div>
        </div>
    </section>
</main>

<footer>
    <div class="container">
        <p>© 2025 Никита Брюханов, ГБПОУ МО «Люберецкий техникум имени Героя Советского Союза, лётчика–космонавта Ю.А. Гагарина»</p>
        <p>Год окончания обучения: 2027 | <a href="#" style="color:var(--accent)">GitHub репозиторий сайта</a></p>
    </div>
</footer>

<script>
    // --- DATA (JSON inline для портативности)---
    const coursesData = [
        { name: "Python-разработчик", platform: "Яндекс Практикум", skills: "Автоматизация, OpenCV, тестирование", image: "https://via.placeholder.com/300x150?text=Сертификат+Python", category: "python", link: "#" },
        { name: "Docker & Контейнеризация", platform: "VK Образование", skills: "Dockerfile, docker-compose, образы", image: "https://via.placeholder.com/300x150?text=Docker", category: "devops", link: "#" },
        { name: "Computer Vision Basics", platform: "СберУниверситет", skills: "CNN, обнаружение объектов", image: "https://via.placeholder.com/300x150?text=OpenCV", category: "ml", link: "#" },
        { name: "Базы данных SQL", platform: "Код будущего", skills: "PostgreSQL, индексы, транзакции", image: "https://via.placeholder.com/300x150?text=SQL", category: "python", link: "#" }
    ];
    const projectsData = [
        { md: "МДК 01.01", title: "Desktop CV App", desc: "Настольное приложение Python + PyQt + OpenCV для анализа изображений. НОВЕЛЛА по производству", role: "Разработчик", repo: "#", gif: "https://media.giphy.com/media/26tn33aiTi1jkl6H6/giphy.gif?cid=790b7611vln2u9mjivj6wljtg7d5mw6h2xnj2vy29pu45vbl&ep=v1_gifs_search&rid=giphy.gif&ct=g" },
        { md: "МДК 01.02", title: "Unit & Integration Tests Suite", desc: "Pytest/unittest + покрытие кода для приложений одногруппников", role: "Тестировщик", repo: "#", gif: "https://media.giphy.com/media/RPls1bBc4Y2Le/giphy.gif?cid=790b7611tg7e817wxto34y5i9z6dz4rrc2xvv1oj7ljs2il1&ep=v1_gifs_search&rid=giphy.gif&ct=g" },
        { md: "МДК 01.03", title: "Mobile CRM Client", desc: "Kivy-приложение для ведения клиентов, APK", role: "Разработчик", repo: "#", gif: "https://media.giphy.com/media/LmNwrBhejkK9EFP504/giphy.gif?cid=790b7611961c0njpxwq1c1hpkbyn9mpkfc93mvt20zhkcl6w&ep=v1_gifs_search&rid=giphy.gif&ct=g" }
    ];
    const practiceData = [
        { name: "Разработка CI/CD для отдела ИТ", profit: "120 000₽", desc: "Настройка GitLab CI, автоматическое тестирование, деплой на Linux", tools: "Docker, Bash, GitLab" },
        { name: "Производственная практика (Техникум)", profit: "Опыт", desc: "Внедрение внутреннего портала, документация, работа с оборудованием", tools: "Python, Django, Linux, systemd" }
    ];

    // SDLC этапы с тултипами
    const sdlcStages = [
        { name: "Планирование", tools: "Notion, Miro, Google Forms", desc: "Сбор требований, CJM, User Stories" },
        { name: "Анализ требований", tools: "Markdown, draw.io", desc: "SRS-документ, диаграммы потоков" },
        { name: "Проектирование", tools: "Figma, Lucidchart, Mermaid", desc: "Архитектура, ERD, UML" },
        { name: "Разработка", tools: "Python, PyQt, FastAPI, OpenCV, Git", desc: "Написание кода, code review" },
        { name: "Тестирование", tools: "pytest, Postman, ручное", desc: "Юнит-тесты, интеграционное" },
        { name: "Развертывание", tools: "Docker, systemd, GitHub Pages", desc: "CI/CD, деплой" },
        { name: "Поддержка", tools: "journalctl, логирование", desc: "Мониторинг, патчи" },
        { name: "Смерть ПО", tools: "архивация tar/gzip", desc: "Миграция данных, уведомления" }
    ];

    function renderCourses(filter = "all") {
        const container = document.getElementById("coursesGrid");
        const filtered = filter === "all" ? coursesData : coursesData.filter(c => c.category === filter);
        container.innerHTML = filtered.map(c => `
            <div class="card">
                <h3>${c.name}</h3>
                <p><strong>${c.platform}</strong></p>
                <p>${c.skills}</p>
                <img src="${c.image}" alt="Сертификат" class="cert-img" loading="lazy">
                <a href="${c.link}" target="_blank">Подробнее →</a>
            </div>
        `).join('');
    }

    function renderProjects() {
        const container = document.getElementById("projectsGrid");
        container.innerHTML = projectsData.map(p => `
            <div class="card">
                <h3>📌 ${p.md}</h3>
                <h4>${p.title}</h4>
                <p>${p.desc}</p>
                <p><strong>Роль:</strong> ${p.role}</p>
                <img src="${p.gif}" alt="Демонстрация" style="max-height:150px; object-fit:cover;">
                <div><a href="${p.repo}" target="_blank">Репозиторий →</a></div>
            </div>
        `).join('');
    }

    function renderPractice() {
        const container = document.getElementById("practiceGrid");
        container.innerHTML = practiceData.map(p => `
            <div class="card">
                <i class="fas fa-briefcase"></i>
                <h3>${p.name}</h3>
                <p>💰 ${p.profit}</p>
                <p>${p.desc}</p>
                <p>🛠️ ${p.tools}</p>
            </div>
        `).join('');
    }

    function renderSDLC() {
        const container = document.getElementById("sdlcContainer");
        container.innerHTML = sdlcStages.map(s => `
            <div class="stage">
                ${s.name}
                <div class="tooltip">
                    <strong>📘 ${s.name}</strong><br>${s.desc}<br>🔧 ${s.tools}
                </div>
            </div>
        `).join('');
    }

    // Фильтры курсов
    document.getElementById("courseFilters")?.addEventListener("click", (e) => {
        if(e.target.classList.contains("filter-btn")){
            document.querySelectorAll(".filter-btn").forEach(btn => btn.classList.remove("active"));
            e.target.classList.add("active");
            renderCourses(e.target.dataset.filter);
        }
    });

    // Twine ссылка (можно разместить реальную html-новеллу)
    document.getElementById("twineLink")?.addEventListener("click", (e) => {
        e.preventDefault();
        alert("Новелла может быть добавлена как отдельный файл: practice-novel.html. Сейчас открывается заглушка.");
        // реальная ссылка: window.open("https://username.github.io/twine-novel/");
    });

    // Theme switcher
    const themeToggle = document.getElementById("themeToggle");
    themeToggle.addEventListener("click", ()=>{
        document.body.classList.toggle("dark");
        const isDark = document.body.classList.contains("dark");
        themeToggle.innerHTML = isDark ? "☀️ Светлая" : "🌙 Тёмная";
        localStorage.setItem("theme", isDark ? "dark" : "light");
    });
    if(localStorage.getItem("theme") === "dark"){
        document.body.classList.add("dark");
        themeToggle.innerHTML = "☀️ Светлая";
    }

    // инициализация
    renderCourses();
    renderProjects();
    renderPractice();
    renderSDLC();

    // Lazy loading images supported natively
    // Можно добавить observer, но уже используется loading="lazy"
</script>
</body>
</html>
